# ============================================================
# HRMS Python 后端环境变量配置模板
# 使用说明：复制此文件为 .env，填入实际值
# API Key 建议配置在系统环境变量中，不要提交到 Git
# ============================================================

# === 数据库配置（PostgreSQL + pgvector） ===
PGVECTOR_HOST=localhost
PGVECTOR_PORT=5432
PGVECTOR_USER=postgres
PGVECTOR_PASSWORD=your_pg_password
PGVECTOR_DATABASE=hrms_db

# === Redis 缓存配置 ===
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# === JWT 认证配置 ===
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# === LLM 主提供商 ===
# 优先读取 .env 中的值，.env 未配置时才回退到系统环境变量
LLM_PRIMARY_PROVIDER=dashscope
LLM_PRIMARY_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_PRIMARY_API_KEY=
LLM_PRIMARY_MODEL=qwen-plus
LLM_PRIMARY_TEMPERATURE=0.7
LLM_PRIMARY_MAX_TOKENS=2048

# === LLM 备用提供商（Ollama 本地） ===
LLM_FALLBACK_PROVIDER=ollama
LLM_FALLBACK_BASE_URL=
LLM_FALLBACK_API_KEY=
LLM_FALLBACK_MODEL=
LLM_FALLBACK_TEMPERATURE=

# === Embedding 向量嵌入 ===
# 优先读取 .env，未配置时回退到系统环境变量，最后使用主 LLM 的 Key
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_DIMENSIONS=1536

# === RAG 检索增强生成配置 ===
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=50
RAG_TOP_K=5

# === Langfuse 可观测性（可选） ===
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key
LANGFUSE_SECRET_KEY=your_langfuse_secret_key
LANGFUSE_HOST=https://cloud.langfuse.com

# === Neo4j 知识图谱配置 ===
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password

# === 高德地图天气 API ===
WEATHER_AMAP_KEY=your_amap_web_service_key

# === Whisper 语音识别配置 ===
WHISPER_MODEL=large-v3
WHISPER_DEVICE=cpu

# === TTS 文字转语音配置 ===
TTS_PROVIDER=edge
TTS_VOICE=zh-CN-XiaoxiaoNeural

# === Token 管理配置 ===
TOKEN_CONTEXT_WINDOW=8192
TOKEN_WARNING_THRESHOLD=0.8
TOKEN_MAX_INPUT=4096

# === 应用配置 ===
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
